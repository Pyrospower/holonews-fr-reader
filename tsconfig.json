{
  "extends": "astro/tsconfigs/strictest",
  "compilerOptions": {
    "jsx": "preserve",
    "types": ["bun"],
    // Skip type checking of external libraries.
    "skipLibCheck": true,
    "paths": {
      "$lib/*": ["./src/*"]
    }
  },
  "include": [
    ".astro/types.d.ts",
    "src",
    "astro.config.mjs",
    "**/*.js",
    "**/*.mjs"
  ]
}
